# Copy to apps/api/.env for local dev. Never commit real secrets.
# In Vercel, set the same variables via `vercel env add` or the dashboard.

PORT=3001
NODE_ENV=development

# Local Docker Postgres (see ../../docker-compose.yml).
# Production: Neon connection string (postgresql://...neon.tech/...?sslmode=require).
DATABASE_URL=postgresql://user:password@localhost:5432/bespoke_vows

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-me-with-a-long-random-string

WEB_ORIGIN=http://localhost:8080

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# File storage. `local` writes to apps/api/uploads/ and serves from /uploads/<key>.
# `vercel` (default) uses Vercel Blob and requires BLOB_READ_WRITE_TOKEN.
STORAGE_DRIVER=local
PUBLIC_API_URL=http://localhost:3001

# Required only when STORAGE_DRIVER=vercel. Set in Vercel dashboard, never commit.
BLOB_READ_WRITE_TOKEN=

MONO_WEBHOOK_SECRET=
